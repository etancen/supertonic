{
  "name": "obsidian-supertonic-tts",
  "version": "1.0.0",
  "description": "Obsidian plugin: speak selected text via SuperTonic TTS API",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "tts",
    "text-to-speech",
    "supertonic"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "~20.0.0",
    "builtin-modules": "^5.1.0",
    "esbuild": "~0.25.0",
    "obsidian": "~1.8.7",
    "tslib": "~2.6.0",
    "typescript": "~5.5.0"
  }
}
